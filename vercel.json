{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/vol2-0",   "dest": "/vol2-0.html" },
    { "src": "/vol2-1",   "dest": "/vol2-1.html" },
    { "src": "/vol3-2",   "dest": "/vol3-2.html" },
    { "src": "/vol3-3",   "dest": "/vol3-3.html" },
    { "src": "/vol3-4",   "dest": "/vol3-4.html" },
    { "src": "/",         "dest": "/index.html" },
    { "src": "/(.*)",     "dest": "/$1" }
  ]
}
